{
  "name": "@cacic-fct/ngx-umami",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "ng build ngx-umami",
    "build:watch": "ng build ngx-umami --watch",
    "test": "ng test ngx-umami",
    "test:coverage": "ng test ngx-umami --no-watch --code-coverage --browsers=ChromeHeadless",
    "lint": "ng lint ngx-umami",
    "lint:fix": "ng lint ngx-umami --fix",
    "format": "prettier --write \"projects/**/*.ts\"",
    "format:check": "prettier --check \"projects/**/*.ts\"",
    "version:patch": "cd projects/ngx-umami && bun version patch --no-git-tag-version",
    "version:minor": "cd projects/ngx-umami && bun version minor --no-git-tag-version",
    "version:major": "cd projects/ngx-umami && bun version major --no-git-tag-version",
    "prepublish:lib": "bun run lint && bun run test:coverage && bun run build",
    "publish:lib": "cd dist/ngx-umami && bun publish --registry https://npm.pkg.github.com"
  },
  "dependencies": {
    "@angular/common": "21.2.12",
    "@angular/core": "21.2.12",
    "@angular/router": "21.2.12",
    "rxjs": "^7.4.0",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular/build": "^21.2.10",
    "@angular/cli": "21.2.10",
    "@angular/compiler": "21.2.12",
    "@angular/compiler-cli": "21.2.12",
    "@angular/platform-browser": "21.2.12",
    "@angular/platform-browser-dynamic": "21.2.12",
    "@eslint/js": "10.0.1",
    "@types/jasmine": "6.0.0",
    "angular-eslint": "21.3.1",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jasmine-core": "6.2.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "ng-packagr": "21.2.3",
    "prettier": "3.8.3",
    "typescript": "5.9",
    "typescript-eslint": "8.59.3",
    "zone.js": "0.16.2"
  }
}